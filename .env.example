# --- Slack (from your "Aunt Linda" app) ---
# Basic Information > App Credentials > Signing Secret
SLACK_SIGNING_SECRET=
# OAuth & Permissions > Bot User OAuth Token (starts with xoxb-)
SLACK_BOT_TOKEN=xoxb-...

# --- ElevenLabs ---
# Profile > API Keys (starts with sk_ or is your xi-api-key)
ELEVENLABS_API_KEY=
# The Linda agent's ID (Agents > Linda > copy agent id from the URL or settings)
ELEVENLABS_AGENT_ID=

# --- Behavior ---
# Comma-separated Slack channel IDs Linda participates in (e.g. the DTC channel).
# Leave blank to allow all channels the bot is in (not recommended).
DTC_CHANNEL_IDS=C0XXXXXXXXX
# If Linda replies with exactly this token, the bridge stays silent (no Slack post).
SILENCE_TOKEN=[[SKIP]]
# Emoji used as the "thinking" indicator while Linda drafts a reply.
THINKING_EMOJI=eyes

# Port the server listens on (most hosts set this automatically).
PORT=3000
