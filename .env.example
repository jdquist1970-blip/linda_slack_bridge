# --- Slack (from your "Aunt Linda" app) ---
# Basic Information > App Credentials > Signing Secret
SLACK_SIGNING_SECRET=
# OAuth & Permissions > Bot User OAuth Token (starts with xoxb-)
SLACK_BOT_TOKEN=xoxb-...

# --- ElevenLabs ---
# Profile > API Keys (starts with sk_ or is your xi-api-key)
ELEVENLABS_API_KEY=
# The Linda agent's ID (Agents > Linda > copy agent id from the URL or settings)
ELEVENLABS_AGENT_ID=

# --- Behavior ---
# Comma-separated Slack channel IDs Linda participates in (e.g. the DTC channel).
# Leave blank to allow all channels the bot is in (not recommended).
DTC_CHANNEL_IDS=C0XXXXXXXXX
# If Linda replies with exactly this token, the bridge stays silent (no Slack post).
SILENCE_TOKEN=[[SKIP]]
# Emoji used as the "thinking" indicator while Linda drafts a reply.
THINKING_EMOJI=eyes

# Port the server listens on (most hosts set this automatically).
PORT=3000

# --- Swyfft quote tools (ElevenLabs webhook tools) ---
# Google Geocoding API key (server key; enable "Geocoding API" in Google Cloud)
GOOGLE_MAPS_API_KEY=
# Shared secret the ElevenLabs webhook tools must send in the X-Tool-Secret header
QUOTE_TOOL_SECRET=
# Defaults are fine; override only if the site endpoints move
# QUOTE_API_URL=https://askauntlinda.com/api/swyfft-quote
# EMAIL_QUOTE_API_URL=https://askauntlinda.com/api/email-quote
# Name attached to Slack-originated quotes (so they're easy to spot in leads)
# QUOTE_LEAD_FIRST_NAME=Slack
# QUOTE_LEAD_LAST_NAME=Internal
